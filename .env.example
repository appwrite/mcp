# Appwrite Cloud base endpoint. The per-project OAuth authorization server lives
# under it at <APPWRITE_ENDPOINT>/oauth2/<project_id>.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# External URL clients use to reach THIS MCP server. Used to build the canonical
# resource URI (<MCP_PUBLIC_URL>/<project_id>/mcp) and RFC 9728 metadata.
MCP_PUBLIC_URL=https://mcp.appwrite.io

# HTTP bind address.
HOST=0.0.0.0
PORT=8000

# ── Integration tests only (not used by the running server) ─────────────────
# The live integration suite authenticates to the Appwrite API with an API key.
# APPWRITE_PROJECT_ID=your-project-id
# APPWRITE_API_KEY=your-api-key
